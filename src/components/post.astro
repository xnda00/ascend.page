---
import "../styles/global.css"
const {allPosts} = Astro.props;
const colors = {
    "AI": "#CCF7B6",
    "GFX": "#71B1E4",
    "ANY": "#FFC1C1"
}
---

<main>
    <ul id="posts">
        {allPosts.map((post)=><li class="post" style={`--post-bg: ${colors[String(post.frontmatter.type)]}`}>{post.frontmatter.title}</li>)}
    </ul>
</main>

<style>
    #posts{
        width: var(--postWidth);
        padding: 0;
        margin: 0;
    }

    .post{
        list-style:none;
        width: var(--postWidth);
        background-color: var(--post-bg);
        height: var(--postHeight);
        border-radius: 21px;
        box-sizing: border-box;
        margin-bottom: 48px;
        padding:16px;
    }
</style>